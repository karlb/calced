[
  {"text": "", "variables": {}, "expected": "blank"},
  {"text": "   ", "variables": {}, "expected": "blank"},
  {"text": "# comment", "variables": {}, "expected": "comment"},
  {"text": "  # indented comment", "variables": {}, "expected": "comment"},
  {"text": "@format = fixed(2)", "variables": {}, "expected": "directive"},
  {"text": "@separator = comma", "variables": {}, "expected": "directive"},
  {"text": "@rate USD/EUR = 0.92", "variables": {}, "expected": "directive"},
  {
    "text": "rent 1500",
    "variables": {},
    "expected": [[0,4,true],[4,5,true],[5,9,false]]
  },
  {
    "text": "100 + 200",
    "variables": {},
    "expected": [[0,3,false],[3,4,true],[4,5,false],[5,6,true],[6,9,false]]
  },
  {
    "text": "x = 5",
    "variables": {},
    "expected": [[0,1,false],[1,2,true],[2,3,false],[3,4,true],[4,5,false]]
  },
  {
    "text": "x + 1",
    "variables": {"x": 10},
    "expected": [[0,1,false],[1,2,true],[2,3,false],[3,4,true],[4,5,false]]
  },
  {
    "text": "pi + 1",
    "variables": {},
    "expected": [[0,2,false],[2,3,true],[3,4,false],[4,5,true],[5,6,false]]
  },
  {
    "text": "e + tau",
    "variables": {},
    "expected": [[0,1,false],[1,2,true],[2,3,false],[3,4,true],[4,7,false]]
  },
  {
    "text": "100 cm in inches",
    "variables": {},
    "expected": [[0,3,false],[3,4,true],[4,6,false],[6,7,true],[7,9,false],[9,10,true],[10,16,false]]
  },
  {
    "text": "sqrt(16)",
    "variables": {},
    "expected": [[0,4,false],[4,5,false],[5,7,false],[7,8,false]]
  },
  {
    "text": "total",
    "variables": {},
    "expected": [[0,5,false]]
  },
  {
    "text": "  rent 1500",
    "variables": {},
    "expected": [[0,2,true],[2,6,true],[6,7,true],[7,11,false]]
  },
  {
    "text": "hello world",
    "variables": {},
    "expected": [[0,5,true],[5,6,true],[6,11,true]]
  },
  {
    "text": "price 10 + tax 5",
    "variables": {},
    "expected": [[0,5,true],[5,6,true],[6,8,false],[8,9,true],[9,10,false],[10,11,true],[11,14,true],[14,15,true],[15,16,false]]
  },
  {
    "text": "test! (here)",
    "variables": {},
    "expected": [[0,4,true],[4,6,true],[6,7,true],[7,11,true],[11,12,true]]
  },
  {
    "text": "University of Michigan",
    "variables": {},
    "expected": [[0,10,true],[10,11,true],[11,13,true],[13,14,true],[14,22,true]]
  },
  {
    "note": "\"of\" dimmed when not preceded by PCT",
    "text": "25 of something",
    "variables": {},
    "expected": [[0,2,false],[2,3,true],[3,5,true],[5,6,true],[6,15,true]]
  },
  {
    "note": "backticks (gaps) dimmed around number",
    "text": "`42` here",
    "variables": {},
    "expected": [[0,1,true],[1,3,false],[3,5,true],[5,9,true]]
  },
  {
    "note": "parens dimmed when they don't contain valid math",
    "text": "(just) 100",
    "variables": {},
    "expected": [[0,1,true],[1,5,true],[5,6,true],[6,7,true],[7,10,false]]
  },
  {
    "note": "comma dimmed when not part of function call",
    "text": "thing, 50",
    "variables": {},
    "expected": [[0,5,true],[5,6,true],[6,7,true],[7,9,false]]
  },
  {
    "note": "trailing comma ignored, number still active",
    "text": "2 foo,",
    "variables": {},
    "expected": [[0,1,false],[1,2,true],[2,5,true],[5,6,true]]
  },
  {
    "note": "trailing comma dimmed, inner comma in function call still active",
    "text": "max(2, 3),",
    "variables": {},
    "expected": [[0,3,false],[3,4,false],[4,5,false],[5,6,false],[6,7,true],[7,8,false],[8,9,false],[9,10,true]]
  },
  {
    "note": "trailing parenthetical annotation ignored, math still active",
    "text": "2*3 (note)",
    "variables": {},
    "expected": [[0,1,false],[1,2,false],[2,3,false],[3,4,true],[4,5,true],[5,9,true],[9,10,true]]
  },
  {
    "note": "as % of highlights all tokens",
    "text": "10 as % of 50",
    "variables": {},
    "expected": [[0,2,false],[2,3,true],[3,5,false],[5,6,true],[6,7,false],[7,8,true],[8,10,false],[10,11,true],[11,13,false]]
  },
  {
    "note": "total expression with variable highlights all tokens",
    "text": "sum + first_half",
    "variables": {"first_half": 300},
    "expected": [[0,3,false],[3,4,true],[4,5,false],[5,6,true],[6,16,false]]
  },
  {
    "note": "variable assignment from total highlights all tokens",
    "text": "gesamt = sum",
    "variables": {},
    "expected": [[0,6,false],[6,7,true],[7,8,false],[8,9,true],[9,12,false]]
  }
]
