1234.5678                               # => 1,235
@format = fixed(2)
1234.5678                               # => 1,234.57
@format = scientific
1234.5678                               # => 1.23e+03
@format = scientific(5)
1234.5678                               # => 1.2346e+03
@format = auto(4)
1234.5678                               # => 1235
@format = minSig(5)
1234.5678                               # => 1,234.6
