# Monthly Budget

rent 1500                               # => 1,500
groceries 200 + 150                     # => 350
utilities 80 + 45 + 30                  # => 155
entertainment 75                        # => 75
total                                   # => 2,080

# Tax Calculation

income = 5000                           # => 5,000
tax_rate = 22%                          # => 0.22
tax = income * tax_rate                 # => 1,100
after_tax = income - tax                # => 3,900

# Fun Math

2 ^ 10                                  # => 1,024
50% of 300                              # => 150
200 + 15%                               # => 230
1k + 500                                # => 1,500
10 * 1.5M                               # => 15,000,000
(100 + 50) * 2                          # => 300
